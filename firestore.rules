rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Phase 4: Validation Blueprints
    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'senderName', 'uid', 'visibility', 'timestamp']) &&
             data.keys().size() >= 5 && // allow optional avatarSeed
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.senderName is string && data.senderName.size() > 0 && data.senderName.size() <= 50 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 100 &&
             data.visibility == 'public' &&
             data.timestamp == request.time;
    }

    function isValidVipUsage(data) {
      return data.keys().hasAll(['toolName', 'uid', 'timestamp']) &&
             data.toolName is string && data.toolName.size() <= 100 &&
             data.uid is string && data.uid.size() <= 100 &&
             data.timestamp == request.time;
    }

    function isValidAppUser(data) {
      return data.keys().hasAll(['uid', 'status']) &&
             data.uid is string && data.uid.size() <= 100 &&
             data.status in ['active', 'banned'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'timestamp']) &&
             data.title is string && data.message is string &&
             data.timestamp == request.time;
    }

    // Chat Messages Rules
    match /chat_messages/{messageId} {
      allow get, list: if existing().visibility == 'public';
      allow create: if isValidId(messageId) && isValidChatMessage(incoming());
    }

    // VIP Usage
    match /vip_tool_usage/{usageId} {
      allow create: if isValidId(usageId) && isValidVipUsage(incoming());
      allow read, list: if false; // Only admin via service account/console for now
    }

    // App Users
    match /app_users/{userId} {
      allow get: if true; // anyone can check if they are banned
      allow list: if true; 
      allow create, update: if isValidId(userId) && isValidAppUser(incoming());
    }

    // Notifications
    match /notifications/{notifId} {
      allow get, list: if true;
      allow create, update: if true; // simplified for this demo, allow admin to write
    }
  }
}
