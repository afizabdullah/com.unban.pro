{
  "entities": {
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A public chat room message.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The message content"
        },
        "senderName": {
          "type": "string",
          "description": "The display name chosen by the user"
        },
        "avatarSeed": {
          "type": "string",
          "description": "Seed for avatar generation"
        },
        "uid": {
          "type": "string",
          "description": "The ID of the sender"
        },
        "visibility": {
          "type": "string",
          "description": "Visibility flag",
          "enum": ["public"]
        },
        "timestamp": {
          "type": "string",
          "description": "Server timestamp"
        }
      },
      "required": [
        "text",
        "senderName",
        "uid",
        "timestamp"
      ]
    },
    "VipToolUsage": {
      "title": "VIP Tool Usage",
      "description": "Tracking analytics for VIP tools.",
      "type": "object",
      "properties": {
        "toolName": { "type": "string" },
        "targetPhone": { "type": "string" },
        "uid": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["toolName", "uid", "timestamp"]
    },
    "AppUser": {
      "title": "App User",
      "description": "Status tracking for app users (banning).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "lastSeen": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "banned"] },
        "isBlocked": { "type": "boolean" }
      },
      "required": ["uid", "status"]
    },
    "AppNotification": {
      "title": "Notification",
      "description": "Global announcements from admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["title", "message", "timestamp"]
    },
    "AdminRecord": {
      "title": "Admin Record",
      "description": "Whitelist of verified admin users by UID.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["role"]
    },
    "AppAccount": {
      "title": "User Account",
      "description": "Credentials created by admin for user access.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "deviceName": { "type": "string" },
        "isVip": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "banned", "deleted"] },
        "createdAt": { "type": "string" }
      },
      "required": ["username", "password", "status"]
    },
    "GlobalStat": {
      "title": "Global Statistics",
      "description": "Aggregated statistics for the whole system.",
      "type": "object",
      "properties": {
        "totalRequests": { "type": "number" },
        "lastUpdate": { "type": "string" }
      }
    },
    "UnbanRequest": {
      "title": "Unban Request",
      "description": "A record of an unban request made by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "phone": { "type": "string" },
        "reasonId": { "type": "string" },
        "deviceId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["userId", "phone", "reasonId", "deviceId", "timestamp"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Article published by admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "likesCount": { "type": "number" },
        "timestamp": { "type": "string" }
      },
      "required": ["title", "content", "timestamp", "author"]
    },
    "BlogComment": {
      "title": "Blog Comment",
      "description": "User feedback on a blog post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["postId", "uid", "text", "timestamp"]
    },
    "UnbanAppeal": {
      "title": "Meta Unban Appeal",
      "description": "Automated appeal request generated by Meta Unban Engine.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string", "enum": ["temporary", "permanent"] },
        "status": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/chat_messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/ChatMessage"
      },
      "description": "Public chat messages."
    },
    "/vip_tool_usage/{usageId}": {
      "schema": {
        "$ref": "#/entities/VipToolUsage"
      },
      "description": "VIP feature usage tracking."
    },
    "/app_users/{userId}": {
      "schema": {
        "$ref": "#/entities/AppUser"
      },
      "description": "All users of the application."
    },
    "/notifications/{notifId}": {
      "schema": {
        "$ref": "#/entities/AppNotification"
      },
      "description": "Global system notifications."
    },
    "/app_admins/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      },
      "description": "Admin users list."
    },
    "/app_accounts/{accountId}": {
      "schema": {
        "$ref": "#/entities/AppAccount"
      },
      "description": "Accounts managed by admin for access control."
    },
    "/unban_requests/{requestId}": {
      "schema": {
        "$ref": "#/entities/UnbanRequest"
      },
      "description": "Individual unban request logs."
    },
    "/global_stats/counters": {
       "schema": { "$ref": "#/entities/GlobalStat" },
       "description": "Global hit counters."
    },
    "/blog_posts/{postId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Blog articles."
    },
    "/blog_posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/BlogComment" },
      "description": "Comments on articles."
    },
    "/unban_appeals/{appealId}": {
      "schema": { "$ref": "#/entities/UnbanAppeal" },
      "description": "Logs of meta unban engine appeals."
    }
  }
}
